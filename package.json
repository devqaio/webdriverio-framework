{
  "name": "@enterprise/wdio-cucumber-framework",
  "version": "1.0.0",
  "description": "Production-grade, highly scalable end-to-end test automation framework built on WebdriverIO with Cucumber BDD",
  "main": "src/index.js",
  "keywords": [
    "webdriverio",
    "cucumber",
    "bdd",
    "e2e",
    "test-automation",
    "selenium",
    "page-object",
    "enterprise"
  ],
  "author": "Enterprise QA Platform Team",
  "license": "MIT",
  "workspaces": [
    "packages/*"
  ],
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "scripts": {
    "test": "npm run test --workspace=packages/project",
    "test:dev": "npm run test:dev --workspace=packages/project",
    "test:staging": "npm run test:staging --workspace=packages/project",
    "test:prod": "npm run test:prod --workspace=packages/project",
    "test:chrome": "npm run test:chrome --workspace=packages/project",
    "test:firefox": "npm run test:firefox --workspace=packages/project",
    "test:edge": "npm run test:edge --workspace=packages/project",
    "test:headless": "npm run test:headless --workspace=packages/project",
    "test:parallel": "npm run test:parallel --workspace=packages/project",
    "test:docker": "npm run test:docker --workspace=packages/project",
    "test:mobile": "npm run test:mobile --workspace=packages/project",
    "test:cloud": "npm run test:cloud --workspace=packages/project",
    "test:targeted": "npm run test:targeted --workspace=packages/project",
    "test:smoke": "npm run test:smoke --workspace=packages/project",
    "test:regression": "npm run test:regression --workspace=packages/project",
    "test:sanity": "npm run test:sanity --workspace=packages/project",
    "test:rerun": "npm run test:rerun --workspace=packages/project",
    "generate:features": "npm run generate:features --workspace=packages/project",
    "generate:runners": "npm run generate:runners --workspace=packages/project",
    "report:generate": "npm run report:generate --workspace=packages/project",
    "report:allure": "npm run report:allure --workspace=packages/project",
    "report:open": "npm run report:open --workspace=packages/project",
    "report:html": "npm run report:html --workspace=packages/project",
    "lint": "eslint src/ packages/ --ext .js,.ts",
    "lint:fix": "eslint src/ packages/ --ext .js,.ts --fix",
    "format": "prettier --write \"src/**/*.js\" \"packages/**/*.js\"",
    "format:check": "prettier --check \"src/**/*.js\" \"packages/**/*.js\"",
    "validate": "npm run lint && npm run format:check",
    "docker:build": "npm run docker:build --workspace=packages/project",
    "docker:run": "npm run docker:run --workspace=packages/project",
    "docker:down": "npm run docker:down --workspace=packages/project",
    "health-check": "npm run health-check --workspace=packages/project",
    "docs:generate": "npx jsdoc -c jsdoc.config.json",
    "docs:open": "npx jsdoc -c jsdoc.config.json && start docs/api/index.html",
    "docs:clean": "rimraf docs/api"
  },
  "devDependencies": {
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-wdio": "^8.24.0",
    "prettier": "^3.2.0",
    "rimraf": "^5.0.0",
    "jsdoc": "^4.0.0"
  }
}
