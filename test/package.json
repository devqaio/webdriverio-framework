{
  "name": "@enterprise/wdio-tests",
  "version": "1.0.0",
  "description": "End-to-end test suite built on @wdio-framework/ui and @wdio-framework/mobile",
  "private": true,
  "keywords": [
    "webdriverio",
    "cucumber",
    "bdd",
    "e2e",
    "test-automation"
  ],
  "author": "Enterprise QA Platform Team",
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "scripts": {
    "pretest": "node scripts/setup.js",
    "test": "npx wdio run config/wdio.conf.js",
    "test:dev": "npx wdio run config/wdio.dev.js",
    "test:staging": "npx wdio run config/wdio.staging.js",
    "test:prod": "npx wdio run config/wdio.prod.js",
    "test:chrome": "npx wdio run config/wdio.conf.js --capabilities.browserName=chrome",
    "test:firefox": "npx wdio run config/wdio.conf.js --capabilities.browserName=firefox",
    "test:edge": "npx wdio run config/wdio.conf.js --capabilities.browserName=MicrosoftEdge",
    "test:headless": "cross-env HEADLESS=true npx wdio run config/wdio.conf.js",
    "test:parallel": "npx wdio run config/wdio.conf.js --maxInstances=5",
    "test:docker": "npx wdio run config/wdio.docker.js",
    "test:mobile": "npx wdio run config/wdio.mobile.js",
    "test:cloud": "npx wdio run config/wdio.cloud.js",
    "test:targeted": "node scripts/runTargeted.js",
    "test:tags": "npx wdio run config/wdio.conf.js --cucumberOpts.tagExpression",
    "test:smoke": "npx wdio run config/wdio.conf.js --cucumberOpts.tagExpression='@smoke'",
    "test:regression": "npx wdio run config/wdio.conf.js --cucumberOpts.tagExpression='@regression'",
    "test:sanity": "npx wdio run config/wdio.conf.js --cucumberOpts.tagExpression='@sanity'",
    "test:rerun": "npx wdio run config/wdio.conf.js --cucumberOpts.tagExpression='@failed'",
    "generate:features": "node scripts/generateFeatures.js",
    "generate:runners": "node scripts/generateRunners.js",
    "report:generate": "node scripts/generateReport.js",
    "report:allure": "allure generate reports/allure-results --clean -o reports/allure-report && allure open reports/allure-report",
    "report:open": "allure open reports/allure-report",
    "report:timeline": "npx wdio-timeline-reporter-html",
    "report:html": "node scripts/generateCucumberReport.js",
    "report:backup": "node scripts/backupReports.js",
    "lint": "eslint test/ config/ --ext .js,.ts",
    "lint:fix": "eslint test/ config/ --ext .js,.ts --fix",
    "format": "prettier --write \"test/**/*.js\" \"config/**/*.js\"",
    "format:check": "prettier --check \"test/**/*.js\" \"config/**/*.js\"",
    "clean": "node scripts/cleanup.js",
    "clean:reports": "rimraf reports/* screenshots/* videos/* logs/*",
    "validate": "npm run lint && npm run format:check",
    "setup": "node scripts/setup.js",
    "docker:build": "docker-compose -f docker/docker-compose.yml build",
    "docker:run": "docker-compose -f docker/docker-compose.yml up --abort-on-container-exit",
    "docker:down": "docker-compose -f docker/docker-compose.yml down",
    "health-check": "node scripts/healthCheck.js",
    "postinstall": "node scripts/postInstall.js",
    "docs:generate": "npx jsdoc -c jsdoc.config.json",
    "docs:open": "npx jsdoc -c jsdoc.config.json && start docs/api/index.html",
    "docs:clean": "rimraf docs/api"
  },
  "dependencies": {
    "@wdio-framework/ui": "*",
    "@wdio-framework/mobile": "*",
    "@wdio/cli": "^9.0.0",
    "@wdio/cucumber-framework": "^9.0.0",
    "@wdio/local-runner": "^9.0.0",
    "@wdio/spec-reporter": "^9.0.0",
    "@wdio/allure-reporter": "^9.0.0",
    "wdio-timeline-reporter": "^5.1.0",
    "wdio-cucumberjs-json-reporter": "^5.0.0",
    "allure-commandline": "^2.27.0",
    "multiple-cucumber-html-reporter": "^3.6.0",
    "webdriverio": "^9.0.0"
  },
  "devDependencies": {
    "@babel/core": "^7.24.0",
    "@babel/preset-env": "^7.24.0",
    "@babel/register": "^7.24.0",
    "@wdio/appium-service": "^9.0.0",
    "chai": "^4.4.0",
    "cross-env": "^7.0.3",
    "dotenv": "^16.4.0",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-wdio": "^8.24.0",
    "prettier": "^3.2.0",
    "rimraf": "^5.0.0",
    "jsdoc": "^4.0.0"
  }
}
